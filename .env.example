# ============================================================
# WhatIfIBought 环境配置模板（唯一需要手工填值的文件）
#
#   本地开发: cp .env.example .env.local 填值
#             之后 IDEA 直接点 Run，或 ./start-local.ps1 一键起三服务
#   线上部署: 服务器上命名为 .env 放 compose 同目录，容器自动注入
#
#   只有 PG_USER / PG_PASSWORD 必填（缺了启动即报 placeholder 错误）
#   其余不填走默认值也能启动，对应功能降级
#   注意: 注释必须独立成行，行内注释会被当成值的一部分
# ============================================================

# ---- PostgreSQL（必填）----
# docker 部署 HOST 填容器名(如 postgres)或宿主机内网 IP，写 localhost 会指向容器自己
PG_HOST=localhost
PG_PORT=5432
PG_DB=wiib
PG_USER=
PG_PASSWORD=

# ---- Redis ----
# HOST 填法同上；无密码留空
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---- Redis 主从-哨兵（可选，线上高可用，配合 redis-compose.yml 栈）----
# 放开下一行即切哨兵模式（REDIS_HOST/PORT 被忽略，PASSWORD/DB 照常生效）
# 哨兵节点默认 redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379，非默认才需填 REDIS_SENTINEL_NODES
# SPRING_PROFILES_ACTIVE=sentinel
# REDIS_SENTINEL_MASTER=mymaster
# REDIS_SENTINEL_NODES=

# ---- LinuxDo OAuth（可选，不配则关闭 LinuxDo 登录）----
LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=
LINUXDO_REDIRECT_URI=http://localhost:3000/login

# ---- Binance USDT-M Testnet（可选，策略 testnet 轨下单用；不填仅 sim 模拟盘轨可用）----
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET_KEY=

# ---- BlockBeats 快讯（可选，不填新闻功能降级）----
BLOCKBEATS_API_KEY=

# ---- 内部服务间鉴权 token（feed/sim/quant 三进程须同值；不填走统一默认值即可互通，线上建议自定义）----
INTERNAL_API_TOKEN=

# ---- 时区（可选，仅 docker 部署用，默认 Asia/Singapore）----
# TZ=Asia/Shanghai
